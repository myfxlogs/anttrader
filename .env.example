# Anttrader runtime env examples
# Duration values use Go ParseDuration format: 500ms, 5s, 1m

# Quote publish interval for stream worker aggregation flush.
ANTRADER_QUOTE_PUBLISH_INTERVAL=200ms

# Throttle window for quote worker warning logs.
ANTRADER_QUOTE_LOG_THROTTLE_WINDOW=12s

# Throttle window for schedule runner HF warning logs.
ANTRADER_SCHEDULE_LOG_THROTTLE_WINDOW=12s

# Feature flag for MT/EA event-driven scheduler rollout.
# false: keep current behavior; true: enable event-driven migration path progressively.
ANTRADER_SCHEDULE_EVENT_DRIVEN_ENABLED=false

# Low-frequency watchdog interval for schedule runtime fallback checks.
ANTRADER_SCHEDULE_WATCHDOG_INTERVAL=30s

# Throttle window for connection manager runtime warn/error logs.
ANTRADER_CONNECTION_LOG_THROTTLE_WINDOW=20s

# --- 前端构建（Vite，仅 Docker build / 本地 npm run build 前需要时设置）---
# 生产主机直连示例（Docker build 时可通过同名环境变量传入）：
# VITE_API_URL=http://43.255.29.23:8012
# VITE_STREAM_URL=http://43.255.29.23:8012
# 不设时浏览器默认使用当前页面 origin（同域反代 / 本机 :8012 时常可省略）。
